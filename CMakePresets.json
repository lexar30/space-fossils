{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022",
      "displayName": "Windows VS2022 x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/builds/windows-vs2022"
    },
    {
      "name": "linux-ninja-debug",
      "displayName": "Linux Ninja Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/builds/linux-ninja-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-ninja-release",
      "displayName": "Linux Ninja Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/builds/linux-ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-debug",
      "displayName": "Build Windows VS2022 Debug",
      "configurePreset": "windows-vs2022",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs2022-release",
      "displayName": "Build Windows VS2022 Release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "linux-ninja-debug",
      "displayName": "Build Linux Ninja Debug",
      "configurePreset": "linux-ninja-debug"
    },
    {
      "name": "linux-ninja-release",
      "displayName": "Build Linux Ninja Release",
      "configurePreset": "linux-ninja-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vs2022-debug",
      "displayName": "Test Windows VS2022 Debug",
      "configurePreset": "windows-vs2022",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-vs2022-release",
      "displayName": "Test Windows VS2022 Release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-ninja-debug",
      "displayName": "Test Linux Ninja Debug",
      "configurePreset": "linux-ninja-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-ninja-release",
      "displayName": "Test Linux Ninja Release",
      "configurePreset": "linux-ninja-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
